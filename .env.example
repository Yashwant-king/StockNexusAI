# StockNexus AI - Environment Configuration Template

# Flask Secret Key for sessions
SECRET_KEY=your-super-secret-key-change-this

# PostgreSQL / Supabase Database URL
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres.yourproject:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Groq API Key for AI Assistant (LLaMA 3.3)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: OpenRouter API Key for alternative models
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
